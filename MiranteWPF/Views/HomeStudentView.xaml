<UserControl x:Class="MiranteWPF.Views.HomeStudentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Border Background="#1a1a2e" CornerRadius="30" Padding="50">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5" Color="#00d4ff"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🎓 STUDENT" FontSize="52" FontWeight="Black"
                          HorizontalAlignment="Center" Foreground="#00d4ff" Margin="0,0,0,10">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#00d4ff" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="MANAGEMENT SYSTEM" FontSize="28" FontWeight="Light"
                          HorizontalAlignment="Center" Foreground="#16f4d0" Margin="0,0,0,20"/>
                <Rectangle Height="2" Width="300" Margin="0,0,0,30">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#00d4ff" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <TextBlock Text="Manage your students with ease" FontSize="18"
                          HorizontalAlignment="Center" Foreground="#8892b0" Margin="0,0,0,50"
                          FontStyle="Italic"/>
                <Button Command="{Binding OpenStudentManagementCommand, Mode=OneWay}"
                       Padding="50,18" FontSize="18" FontWeight="Bold" Cursor="Hand" BorderThickness="2">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#00d4ff"/>
                            <Setter Property="Foreground" Value="#00d4ff"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               BorderBrush="{TemplateBinding BorderBrush}"
                                               BorderThickness="{TemplateBinding BorderThickness}"
                                               CornerRadius="25" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#00d4ff"/>
                                    <Setter Property="Foreground" Value="#0a192f"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚀 " FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="MANAGE STUDENTS"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
