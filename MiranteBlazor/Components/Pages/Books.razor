@page "/books"
@using Domain.Models
@using Domain.Commands
@using Domain.Queries
@inject IGetAllBooks GetAllBooks
@inject ICreateBook CreateBook
@inject IUpdateBook UpdateBook
@inject IDeleteBook DeleteBook
@rendermode InteractiveServer
<PageTitle>Library</PageTitle>

<div class="mgmt-wrapper">

    <!-- Header -->
    <div class="mgmt-header">
        <span class="mgmt-title">📚 BOOK MANAGEMENT</span>
        <div class="mgmt-divider"></div>
    </div>

    <div class="mgmt-body">

        <!-- Left: Form Panel -->
        <div class="mgmt-form-panel">
            <div class="panel-label">✨ BOOK DETAILS</div>

            <label class="field-label">TITLE</label>
            <div class="field-wrap">
                <input class="mgmt-input" @bind="title" @bind:event="oninput" placeholder="Enter title" />
            </div>

            <label class="field-label">AUTHOR</label>
            <div class="field-wrap">
                <input class="mgmt-input" @bind="author" @bind:event="oninput" placeholder="Enter author" />
            </div>

            <label class="field-label">ISBN</label>
            <div class="field-wrap">
                <input class="mgmt-input" @bind="isbn" @bind:event="oninput" placeholder="Enter ISBN" />
            </div>

            <div class="field-row">
                <div class="field-half">
                    <label class="field-label">YEAR</label>
                    <div class="field-wrap">
                        <input class="mgmt-input" type="number" @bind="yearPublished" @bind:event="oninput" placeholder="Year" />
                    </div>
                </div>
                <div class="field-half">
                    <label class="field-label">GENRE</label>
                    <div class="field-wrap">
                        <input class="mgmt-input" @bind="genre" @bind:event="oninput" placeholder="Genre" />
                    </div>
                </div>
            </div>

            @if (!isEditMode)
            {
                <button class="mgmt-btn mgmt-btn-add" @onclick="HandleCreate">➕ ADD BOOK</button>
            }
            else
            {
                <button class="mgmt-btn mgmt-btn-update" @onclick="HandleUpdate">✏️ UPDATE BOOK</button>
                <button class="mgmt-btn mgmt-btn-cancel" @onclick="ClearForm">✖ CANCEL</button>
            }

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="mgmt-message">@message</div>
            }
        </div>

        <!-- Right: Table Panel -->
        <div class="mgmt-table-panel">
            <div class="panel-label">📖 COLLECTION</div>

            <div class="search-wrap">
                <input class="mgmt-input" @bind="searchText" @bind:event="oninput"
                       placeholder="🔍 Search your library..." />
            </div>

            <div class="mgmt-table-wrap">
                <table class="mgmt-table">
                    <thead>
                        <tr>
                            <th>TITLE</th>
                            <th>AUTHOR</th>
                            <th>ISBN</th>
                            <th>YEAR</th>
                            <th>GENRE</th>
                            <th>ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in FilteredBooks)
                        {
                            <tr>
                                <td>@b.Title</td>
                                <td>@b.Author</td>
                                <td>@b.ISBN</td>
                                <td>@b.YearPublished</td>
                                <td>@b.Genre</td>
                                <td>
                                    <button class="action-btn action-edit" @onclick="() => EditBook(b)">✏️</button>
                                    <button class="action-btn action-delete" @onclick="() => HandleDelete(b)">🗑️</button>
                                </td>
                            </tr>
                        }
                        @if (!FilteredBooks.Any())
                        {
                            <tr>
                                <td colspan="6" class="empty-row">No books found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@code {
    private List<BookModel> books = new();
    private string searchText = string.Empty;
    private string title = string.Empty;
    private string author = string.Empty;
    private string isbn = string.Empty;
    private int yearPublished;
    private string genre = string.Empty;
    private bool isEditMode;
    private int editingId;
    private string message = string.Empty;

    private IEnumerable<BookModel> FilteredBooks => string.IsNullOrWhiteSpace(searchText)
        ? books
        : books.Where(b =>
            b.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            b.Author.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            b.ISBN.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            b.Genre.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await LoadBooks();

    private async Task LoadBooks()
    {
        books = (await GetAllBooks.ExecuteAsync()).ToList();
    }

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(title) || string.IsNullOrWhiteSpace(author)) return;
        await CreateBook.ExecuteAsync(new BookModel { Title = title, Author = author, ISBN = isbn, YearPublished = yearPublished, Genre = genre });
        await LoadBooks();
        ClearForm();
        message = "Book added successfully.";
    }

    private async Task HandleUpdate()
    {
        await UpdateBook.ExecuteAsync(new BookModel { BookId = editingId, Title = title, Author = author, ISBN = isbn, YearPublished = yearPublished, Genre = genre });
        await LoadBooks();
        ClearForm();
        message = "Book updated successfully.";
    }

    private async Task HandleDelete(BookModel b)
    {
        await DeleteBook.ExecuteAsync(b);
        await LoadBooks();
        message = "Book deleted.";
    }

    private void EditBook(BookModel b)
    {
        editingId = b.BookId;
        title = b.Title;
        author = b.Author;
        isbn = b.ISBN;
        yearPublished = b.YearPublished;
        genre = b.Genre;
        isEditMode = true;
        message = string.Empty;
    }

    private void ClearForm()
    {
        editingId = 0;
        title = string.Empty;
        author = string.Empty;
        isbn = string.Empty;
        yearPublished = 0;
        genre = string.Empty;
        isEditMode = false;
    }
}
